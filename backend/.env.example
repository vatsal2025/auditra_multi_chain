# GCP — ADC handles auth automatically on GCP VM (no JSON key file needed)
# On local dev: run `gcloud auth application-default login` instead
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1

# Vertex AI AutoML endpoints — written automatically by deploy_vertex.py after training
VERTEX_AI_ENDPOINT_COMPAS=
VERTEX_AI_ENDPOINT_ADULT=
VERTEX_AI_ENDPOINT_GERMAN=
VERTEX_AI_ENDPOINT_ID=   # generic fallback if dataset-specific endpoint not set

# AI Studio API key (fallback — used only if GCP_PROJECT_ID is blank)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
